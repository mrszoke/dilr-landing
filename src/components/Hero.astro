<section class="hero">
  <div class="hero-left">
    <h1>Olyan akciók, amik tényleg érdekelnek.</h1>

<p class="subtitle">
Egy feed. Nulla zaj.
</p>

<p class="description">
A Dìlr egy személyre szabott ajánlatos felület,
ahol helyi üzletek és márkák ajánlatait látod –
az érdeklődésed és a tartózkodási helyed alapján.
</p>

<strong class="tagline">
Nincs reklám. Nincs spam. Csak relevancia.
</strong>

<form id="notify-form" class="flex flex-col items-center gap-3 mt-6">

  

  <!-- HEADLINE -->

  <p class="text-lg font-semibold text-center">

    Legyél az elsők között

  </p>

  <!-- SUBTEXT -->

  <p class="text-sm text-gray-500 text-center max-w-md">

    Az elsők között férsz hozzá Budapest legjobb ajánlataihoz.

  </p>

  <!-- INPUT -->

  <input 

    type="email" 

    name="email" 

    placeholder="Add meg az email címed"

    required

    class="w-full max-w-sm px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-purple-500"

  />

  <!-- BUTTON -->

  <button 

    type="submit"

    class="px-6 py-3 rounded-xl bg-purple-600 text-white font-medium hover:bg-purple-700 transition"

  >

    Érdekel – szóljatok induláskor

  </button>

  <!-- TRUST -->

  <p class="text-xs text-gray-400">

    Nem küldünk spamet.

  </p>

</form>

<!-- SUCCESS MESSAGE -->

<p id="success" class="hidden mt-4 text-green-600 font-medium">

  Köszi! Szólunk, amint indulunk 🚀

</p>

<p class="cta-note">
  A korai felhasználók elsőként kapnak hozzáférést.
</p>

  </div>

<div class="hero-right">
  <div class="phone-mockup">
    <img
      src="/app-mockup.png"
      alt="Dilr app preview"
      loading="lazy"
    />
  </div>
</div>
</section>

<script>

  const form = document.getElementById('notify-form');

  const success = document.getElementById('success');

  form.addEventListener('submit', async (e) => {

    e.preventDefault();

    const email = form.email.value;

    await fetch('/api/notify', {

      method: 'POST',

      body: JSON.stringify({ email }),

    });

    form.reset();

    success.classList.remove('hidden');

  });

</script>
